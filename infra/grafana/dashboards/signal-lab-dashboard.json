      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        { "expr": "sum by (type, status) (scenario_runs_total)", "legendFormat": "{{type}} / {{status}}", "refId": "A" }
      ],
      "title": "Scenario Runs by Type (Total)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        { "expr": "sum by (type) (scenario_run_duration_seconds_sum) / sum by (type) (scenario_run_duration_seconds_count)", "legendFormat": "{{type}} avg", "refId": "A" }
      ],
      "title": "Average Scenario Latency (seconds)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "sum by (type) (scenario_runs_total{status=\"error\"})", "legendFormat": "{{type}}", "refId": "A" }
      ],
      "title": "Error Runs by Scenario Type (Total)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
